{% extends "base.njk" %}

{% block content %}
  {% include "partials/breadcrumbs.njk" %}
  <article class="page">
    <h1 class="page-title">{{ page.title }}</h1>
    <div class="page-body{% if page.isPydoc %} pydoc-page{% endif %}">
      {{ page.contentHtml | safe }}
    </div>
  </article>
{% endblock %}
